{
  "manifest_version": 3,
  "name": "Scam Site Detector",
  "version": "1.0",
  "description": "Automatically checks the current website against a detection engine to warn you of scams.",
  "permissions": [
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Check Site Security"
  }
}